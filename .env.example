# App URLs
NEXT_PUBLIC_SITE_URL=https://www.afterservice.app
NEXT_PUBLIC_DASHBOARD_URL=https://dashboard.afterservice.app
NEXT_PUBLIC_API_URL=https://dashboard.afterservice.app/api
SITE_PORT=4100
DASHBOARD_PORT=4101
API_PORT=4102
PORT=4102
AFTERSERVICE_KILL_PORTS="4100 4101 4102 5555"

# Portless (dev-only, optional)
# SITE_PORTLESS_ROOT_DOMAIN=afterservice.localhost
# DASHBOARD_PORTLESS_ROOT_DOMAIN=app-afterservice.localhost
# API_PORTLESS_ROOT_DOMAIN=api-afterservice.localhost
# SITE_ROOT_DOMAIN=www.afterservice.app
# DASHBOARD_ROOT_DOMAIN=dashboard.afterservice.app
# API_ROOT_DOMAIN=dashboard.afterservice.app

# Database
DATABASE_URL=postgresql://anodizex:anodizex@localhost:55435/anodizex

# Auth
AUTH_SECRET=
AUTH_TRUSTED_ORIGINS=https://afterservice.app,https://www.afterservice.app,https://dashboard.afterservice.app
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://dashboard.afterservice.app
BETTER_AUTH_TRUSTED_ORIGINS=https://afterservice.app,https://www.afterservice.app,https://dashboard.afterservice.app
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AFTERSERVICE_AUTH_DEBUG=false

# Polar
# Leave false during free beta. Set true only when paid checkout is intentionally live.
AFTERSERVICE_PAID_CHECKOUT_ENABLED=false
POLAR_ACCESS_TOKEN=
POLAR_ORGANIZATION_ID=
POLAR_WEBHOOK_SECRET=
# Public plan mapping: starter = Starter after beta, growth = Shop, pro = Growth.
POLAR_STARTER_VARIANT_ID=
POLAR_SHOP_VARIANT_ID=
POLAR_GROWTH_VARIANT_ID=

# Email
EMAIL_FROM_ADDRESS=
RESEND_API_KEY=
# Outside production mode, customer-facing outbound email is redirected here.
# Also used as the production recipient for internal owner reports.
TEST_EMAIL=

# Media import
BLOB_READ_WRITE_TOKEN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_IMPORT_CHAT_ID=
# Optional: choose a specific workspace for Telegram imports. Defaults to the first workspace.
TELEGRAM_IMPORT_WORKSPACE_ID=
TELEGRAM_IMPORT_WORKSPACE_SLUG=

# Jobs
CRON_SECRET=
FOLLOW_UP_DRY_RUN=true
# Optional Trigger.dev CLI profile. Leave blank to use the CLI default profile.
TRIGGER_PROFILE=
TRIGGER_PROJECT_ID=
TRIGGER_SECRET_KEY=

# Observability
LOG_LEVEL=info
NEXT_PUBLIC_SENTRY_DSN=
GOOGLE_SITE_VERIFICATION=
OPENPANEL_PROJECT_ID=
OPENPANEL_READ_CLIENT_ID=
OPENPANEL_READ_CLIENT_SECRET=
SENTRY_ORG=cipron-concepts
SENTRY_PROJECT=anodizex
SENTRY_AUTH_TOKEN=
SENTRY_RELEASE=
