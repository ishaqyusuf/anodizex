{
  "name": "@anodizex/website",
  "private": true,
  "scripts": {
    "build": "bun ../../scripts/with-workspace-env.mjs --mode production -- next build --turbopack",
    "dev": "bun ../../scripts/with-workspace-env.mjs --mode local -- next dev --turbopack -p 4100",
    "dev:portless": "PORTLESS_APP_PORT=${PORTLESS_APP_PORT:-4100} PORTLESS_WILDCARD=${PORTLESS_WILDCARD:-1} PORTLESS_SYNC_HOSTS=${PORTLESS_SYNC_HOSTS:-0} portless afterservice next dev --turbopack",
    "lint": "biome check .",
    "pwa:verify": "bun ../../scripts/verify-website-pwa.mjs",
    "start": "bun ../../scripts/with-workspace-env.mjs --mode production -- next start -p 4100",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anodizex/api": "workspace:*",
    "@anodizex/events": "workspace:*",
    "@anodizex/plans": "workspace:*",
    "@anodizex/site-nav": "workspace:*",
    "@anodizex/ui": "workspace:*",
    "@anodizex/utils": "workspace:*",
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.100.14",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "@trpc/tanstack-react-query": "^11.17.0",
    "lucide-react": "^1.17.0",
    "next": "^16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.77.0",
    "superjson": "^2.2.6",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@anodizex/tsconfig": "workspace:*",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.9.3"
  }
}
