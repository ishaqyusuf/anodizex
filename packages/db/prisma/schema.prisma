generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum WorkspacePlan {
  starter
  growth
  pro
}

enum WorkspacePlanStatus {
  trialing
  active
  past_due
  canceled
}

enum MembershipRole {
  owner
  admin
  staff
}

enum ServiceJobStatus {
  completed
  needs_follow_up
  resolved
}

enum FollowUpStatus {
  open
  scheduled
  sent
  replied
  closed
  missed
}

enum FollowUpChannel {
  email
  sms
  phone
  whatsapp
}

enum BillingProvider {
  polar
  stripe
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String       @default("")
  emailVerified Boolean      @default(false)
  image         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  accounts      Account[]
  memberships   Membership[]
  sessions      Session[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
}

model Workspace {
  id                       String              @id @default(cuid())
  name                     String
  slug                     String              @unique
  businessType             String?
  serviceCategory          String?
  defaultFollowUpDelayDays Int                 @default(7)
  plan                     WorkspacePlan       @default(starter)
  planStatus               WorkspacePlanStatus @default(trialing)
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  billingEvents            BillingEvent[]
  customers                Customer[]
  followUpEvents           FollowUpEvent[]
  followUps                FollowUp[]
  invites                  TeamInvite[]
  jobs                     ServiceJob[]
  memberships              Membership[]
  messageLogs              MessageLog[]
  subscriptions            Subscription[]
  templates                FollowUpTemplate[]
}

model Membership {
  id          String         @id @default(cuid())
  workspaceId String
  userId      String
  role        MembershipRole @default(staff)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model TeamInvite {
  id          String         @id @default(cuid())
  workspaceId String
  email       String
  role        MembershipRole @default(staff)
  token       String         @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, email])
}

model Customer {
  id            String       @id @default(cuid())
  workspaceId   String
  name          String
  phone         String?
  email         String?
  companyName   String?
  preferredChannel FollowUpChannel @default(email)
  tags          String[]     @default([])
  notes         String?
  lastServiceAt DateTime?
  archivedAt    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  followUps     FollowUp[]
  jobs          ServiceJob[]
  messageLogs   MessageLog[]
  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, archivedAt])
  @@index([workspaceId, name])
}

model ServiceJob {
  id              String           @id @default(cuid())
  workspaceId     String
  customerId      String
  staffOwnerId    String?
  title           String
  serviceCategory String?
  completedAt     DateTime
  amountCents     Int?
  notes           String?
  nextFollowUpAt  DateTime?
  status          ServiceJobStatus @default(completed)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  customer        Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  followUps       FollowUp[]
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, completedAt])
  @@index([workspaceId, customerId])
}

model FollowUp {
  id          String            @id @default(cuid())
  workspaceId String
  customerId  String
  jobId       String?
  templateId  String?
  assigneeId  String?
  status      FollowUpStatus    @default(open)
  channel     FollowUpChannel   @default(email)
  dueAt       DateTime
  sentAt      DateTime?
  closedAt    DateTime?
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  customer    Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  events      FollowUpEvent[]
  job         ServiceJob?       @relation(fields: [jobId], references: [id], onDelete: SetNull)
  messageLogs MessageLog[]
  template    FollowUpTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, dueAt])
  @@index([workspaceId, status])
  @@index([workspaceId, customerId])
}

model FollowUpTemplate {
  id          String          @id @default(cuid())
  workspaceId String
  name        String
  channel     FollowUpChannel @default(email)
  subject     String?
  body        String
  isDefault   Boolean         @default(false)
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  followUps   FollowUp[]
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name])
}

model FollowUpEvent {
  id          String    @id @default(cuid())
  workspaceId String
  followUpId  String
  actorId     String?
  type        String
  metadata    Json?
  createdAt   DateTime  @default(now())
  followUp    FollowUp  @relation(fields: [followUpId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, followUpId])
}

model MessageLog {
  id          String          @id @default(cuid())
  workspaceId String
  customerId  String?
  followUpId  String?
  channel     FollowUpChannel
  recipient   String
  subject     String?
  body        String
  provider    String?
  providerId  String?
  errorDetails Json?
  status      String          @default("draft")
  sentAt      DateTime?
  createdAt   DateTime        @default(now())
  customer    Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  followUp    FollowUp?       @relation(fields: [followUpId], references: [id], onDelete: SetNull)
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([workspaceId, followUpId])
}

model Subscription {
  id                 String              @id @default(cuid())
  workspaceId        String
  provider           BillingProvider     @default(polar)
  providerCustomerId String?
  providerSubId      String              @unique
  variantId          String?
  status             WorkspacePlanStatus @default(trialing)
  currentPeriodEnd   DateTime?
  canceledAt         DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  workspace          Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model BillingEvent {
  id          String          @id @default(cuid())
  workspaceId String?
  provider    BillingProvider @default(polar)
  providerId  String          @unique
  eventName   String
  payload     Json
  processedAt DateTime?
  createdAt   DateTime        @default(now())
  workspace   Workspace?      @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
}
