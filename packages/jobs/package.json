{
  "name": "@afterservice/jobs",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "deploy": "bun run prisma.ts && bun run --filter @afterservice/db db:generate && bun ../../scripts/with-workspace-env.mjs --mode production -- bun ../../scripts/with-trigger-profile.mjs -- trigger deploy",
    "dev": "bun ../../scripts/with-workspace-env.mjs --mode local -- bun ../../scripts/with-trigger-profile.mjs -- trigger dev",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@afterservice/db": "workspace:*",
    "@afterservice/notifications": "workspace:*",
    "@trigger.dev/build": "4.0.1",
    "@trigger.dev/sdk": "4.0.1"
  },
  "devDependencies": {
    "@afterservice/tsconfig": "workspace:*",
    "@types/node": "^25.2.3",
    "trigger.dev": "4.0.1",
    "typescript": "^5.9.3"
  }
}
