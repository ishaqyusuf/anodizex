{
  "$schema": "https://turborepo.org/schema.json",
  "globalDependencies": ["**/.env", "**/.env.production"],
  "globalEnv": [
    "API_PUBLIC_URL",
    "AUTH_SECRET",
    "AUTH_TRUSTED_ORIGINS",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_TRUSTED_ORIGINS",
    "BETTER_AUTH_URL",
    "BLOB_READ_WRITE_TOKEN",
    "CRON_SECRET",
    "DATABASE_URL",
    "IS_LAUNCHED",
    "POLAR_ACCESS_TOKEN",
    "POLAR_ORGANIZATION_ID",
    "POLAR_WEBHOOK_SECRET",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_DASHBOARD_URL",
    "NEXT_PUBLIC_SITE_URL",
    "EMAIL_FROM_ADDRESS",
    "RESEND_API_KEY",
    "TEST_EMAIL",
    "NEXT_PUBLIC_SENTRY_DSN",
    "SENTRY_AUTH_TOKEN",
    "SENTRY_ORG",
    "SENTRY_PROJECT",
    "SENTRY_RELEASE",
    "TRIGGER_PROFILE",
    "TRIGGER_PROJECT_ID",
    "TRIGGER_SECRET_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**",
        "generated/**",
        "build/**",
        "lib/**"
      ]
    },
    "clean": {
      "cache": false
    },
    "db:migrate": {
      "cache": false,
      "interactive": true
    },
    "db:generate": {
      "cache": false,
      "outputs": ["generated/**"]
    },
    "db:push": {
      "cache": false,
      "interactive": true
    },
    "db:validate": {
      "cache": false,
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:portless": {
      "cache": false,
      "persistent": true
    },
    "format": {},
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    }
  },
  "ui": "tui"
}
